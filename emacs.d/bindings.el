(defvar ergo-minor-mode-map (make-sparse-keymap)
  "ergo-minor-mode keymap.")

(define-minor-mode ergo-minor-mode
  "A minor mode so that my key settings override annoying major modes."
  nil
  :lighter nil
  :global t
  :keymap ergo-minor-mode-map)

