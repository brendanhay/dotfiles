(mapcar (lambda (binding)
          (let ((key (car binding))
                (cmd (cdr binding)))
            (define-key ergo-minor-mode-map key nil)
            (define-key ergo-minor-mode-map key cmd)
            key))
          ergo-bindings)

(defun my-minibuffer-setup-hook ()
  (ergo-minor-mode 0))

(provide 'ergo-minor-mode)
(ergo-minor-mode)
